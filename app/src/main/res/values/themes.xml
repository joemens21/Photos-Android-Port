<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- NoActionBar base so we control placement; AppCompatActivity adds the bar above content -->
    <style name="Theme.Photos" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">#1976D2</item>
        <item name="colorPrimaryDark">#0D47A1</item>
        <item name="colorAccent">#42A5F5</item>
        <!-- Prevent action bar from overlapping content -->
        <item name="windowActionBarOverlay">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:fitsSystemWindows">true</item>
    </style>
</resources>
